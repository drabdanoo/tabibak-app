rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isDoctor() {
      return isAuthenticated() && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'doctor';
    }
    
    function isReceptionist() {
      return isAuthenticated() && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'receptionist';
    }

    // Users collection
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow write: if isOwner(userId);
    }
    
    // Doctors collection
    match /doctors/{doctorId} {
      allow read: if true; // Public profiles
      allow write: if isOwner(doctorId);
    }
    
    // Patients collection
    match /patients/{patientId} {
      allow read: if isOwner(patientId) || isDoctor() || isReceptionist();
      allow write: if isOwner(patientId);
    }
    
    // Receptionists collection
    match /receptionists/{receptionistId} {
      allow read: if isAuthenticated();
      allow write: if isOwner(receptionistId);
    }
    
    // Appointments collection
    match /appointments/{appointmentId} {
      allow read: if isAuthenticated() && (
        resource.data.patientId == request.auth.uid || 
        resource.data.doctorId == request.auth.uid ||
        isReceptionist() // Refine this to check clinicId if possible
      );
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && (
        resource.data.patientId == request.auth.uid || 
        resource.data.doctorId == request.auth.uid ||
        isReceptionist()
      );
      allow delete: if false; // Don't allow deleting appointments, only cancelling
    }
    
    // Medical Documents
    match /medicalDocuments/{docId} {
      allow read: if isAuthenticated() && (
        resource.data.patientId == request.auth.uid || 
        resource.data.doctorId == request.auth.uid
      );
      allow write: if isDoctor();
    }
    
    // User Tokens (for notifications)
    match /userTokens/{userId} {
      allow read, write: if isOwner(userId);
    }
  }
}
