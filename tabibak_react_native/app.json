{
  "expo": {
    "name": "Vanbook",
    "slug": "tabibok-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": false,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#10b981"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.vantaq.vanbook",
      "googleServicesFile": "./GoogleService-Info.plist",
      "buildNumber": "2",
      "config": {
        "googleMapsApiKey": "AIzaSyAnsDB584i5_CDzAyTOjRnLFdeoTti6Yew"
      },
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSCameraUsageDescription": "Allow camera access to take photos for profile pictures and document uploads",
        "NSPhotoLibraryUsageDescription": "Allow access to photo library to select profile pictures and documents",
        "NSPhotoLibraryAddUsageDescription": "Vanbook needs permission to save documents to your photo library.",
        "NSLocationWhenInUseUsageDescription": "Vanbook uses your location to show nearby providers on the map.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "Vanbook uses your location to show nearby providers on the map.",
        "NSMicrophoneUsageDescription": "Allow microphone access for video recording (if applicable)",
        "NSUserNotificationsUsageDescription": "Vanbook sends notifications for appointment reminders and messages."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#10b981"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.abdullah.vanbook",
      "googleServicesFile": "./google-services.json",
      "versionCode": 15
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "c6e91624-4f76-4b03-90f1-f4f724ab5547"
      }
    },
    "owner": "abdanoo",
    "plugins": [
      "./plugins/withFirebaseFix",
      "expo-localization",
      [
        "expo-notifications",
        {
          "icon": "./assets/adaptive-icon.png",
          "color": "#10b981",
          "defaultChannel": "default",
          "androidMode": "default"
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "compileSdkVersion": 35,
            "targetSdkVersion": 35,
            "minSdkVersion": 24,
            "buildToolsVersion": "35.0.0"
          },
          "ios": {
            "useFrameworks": "static"
          }
        }
      ]
    ]
  }
}
