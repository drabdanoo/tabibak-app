# EAS archive exclusions
# Ref: https://expo.fyi/eas-build-archive

# Dependencies (biggest culprit — ~300-500MB)
node_modules/
/node_modules

# Native folders (auto-generated by EAS)
/android
/ios

# Expo local cache
/.expo

# Lock files (not needed by EAS)
package-lock.json
yarn.lock

# Documentation files (clutter)
*.md
!README.md

# IDE / editor folders
/.idea
/.vscode

# Scripts (not needed for build)
/scripts

# Misc
.DS_Store
*.log
npm-debug.*
yarn-debug.*
yarn-error.*

# Learn more https://docs.github.com/en/get-started/getting-started-with-git/ignoring-files

# dependencies
node_modules/

# Expo
.expo/
dist/
web-build/
expo-env.d.ts

# Native
.kotlin/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# Metro
.metro-health-check*

# debug
npm-debug.*
yarn-debug.*
yarn-error.*

# macOS
.DS_Store
*.pem

# local env files
.env*.local

# typescript
*.tsbuildinfo

# generated native folders
/ios
/android

